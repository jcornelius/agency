# Digger bot — copy to .env and fill in values
# .env is gitignored; never commit real keys.

# --- Slack ---
# Create a Slack app at https://api.slack.com/apps. Enable Socket Mode.
# Bot User OAuth Token (xoxb-...) from "OAuth & Permissions" page.
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# App-Level Token (xapp-...) with connections:write scope, from "Basic Information" → App-Level Tokens.
SLACK_APP_TOKEN=xapp-your-app-token-here

# --- Anthropic (used by the bot's command parser only) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional: override model used for command parsing
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Prospect pipeline API keys (used by prospect-search.py + email-finder.py) ---
BRAVE_API_KEY=your-brave-key
GOOGLE_PLACES_API_KEY=your-google-places-key
HUBSPOT_PRIVATE_APP_TOKEN=your-hubspot-private-app-token
HUNTER_API_KEY=your-hunter-key

# Optional email-finder fallbacks
# APOLLO_API_KEY=
# ZEROBOUNCE_API_KEY=

# --- Paths ---
# Directory containing prospect-search.py and email-finder.py.
# Defaults to ../scripts relative to bot/ if unset.
# DIGGER_SCRIPTS_DIR=/Users/jc/Nest/digger/scripts

# Brief file that defines keyword matching rules and defaults.
# Defaults to ../briefs/square-pos-research.md relative to bot/ if unset.
# DIGGER_BRIEF_PATH=/Users/jc/Nest/digger/briefs/square-pos-research.md

# CSV output directory.
# Defaults to ../research relative to bot/ if unset.
# DIGGER_RESEARCH_DIR=/Users/jc/Nest/digger/research

# --- Behavior ---
# Comma-separated Slack user IDs or channel IDs allowed to invoke @digger.
# Leave blank to allow anyone in the workspace.
DIGGER_ALLOWED_USERS=
DIGGER_ALLOWED_CHANNELS=
